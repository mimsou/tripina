{
  "name": "triphive",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "ors:up": "docker compose -f docker-compose.ors.yml up -d",
    "ors:down": "docker compose -f docker-compose.ors.yml down",
    "dev:with-ors": "docker compose -f docker-compose.ors.yml up -d && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:ensure": "node --env-file=.env scripts/ensure-db.mjs",
    "db:setup": "node --env-file=.env scripts/ensure-db.mjs && prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "realtime": "npx tsx server/realtime.ts",
    "test": "vitest"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fastify/cors": "^11.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "5.22.0",
    "@tanstack/react-query": "^5.96.2",
    "@uploadthing/react": "^7.3.3",
    "@vercel/og": "^0.11.1",
    "date-fns": "^4.1.0",
    "fastify": "^5.8.4",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "maplibre-gl": "^4.7.1",
    "nanoid": "^5.1.7",
    "next": "14.2.35",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "prisma": "5.22.0",
    "qrcode.react": "^4.2.0",
    "react": "^18",
    "react-dom": "^18",
    "react-email": "^5.2.10",
    "react-hook-form": "^7.72.1",
    "resend": "^6.10.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.183.2",
    "uploadthing": "^7.7.4",
    "zod": "^3.24.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/three": "^0.170.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "pg": "^8.20.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^3.0.5"
  }
}
