# App (must match the URL you open in the browser — use the same host as localhost vs 127.0.0.1)
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# Secret for Auth.js (required for production builds; dev falls back if both empty)
# Generate: openssl rand -base64 32
AUTH_SECRET=triphive-local-dev-secret-minimum-32-characters-long
# NEXTAUTH_SECRET=

# Google OAuth — in Google Cloud Console add Authorized redirect URI:
#   {NEXTAUTH_URL}/api/auth/callback/google
# e.g. http://localhost:3000/api/auth/callback/google
# Or use Auth.js v5 names: AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database — use postgresql://… (not prisma+postgres). Create DB: npm run db:setup
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/triphive

# OpenRouteService — directions / matrice (serveur uniquement). https://openrouteservice.org/
# Cas courant (ex. Windows, sans ORS local) : gardez l’URL publique ci-dessous et une clé depuis le
# dashboard ORS — pas besoin de docker-compose.ors.yml.
# Self-hosted en prod (Render) : le blueprint peut définir OPENROUTESERVICE_HOSTPORT (réseau privé)
# vers le service ORS ; laissez OPENROUTESERVICE_BASE_URL vide dans ce cas.
# Option manuelle : OPENROUTESERVICE_BASE_URL=https://votre-serveur-ors/ors (sans OPENROUTESERVICE_HOSTPORT).
# URL de base sans slash final. Laisser vide si OPENROUTESERVICE_HOSTPORT est utilisé.
OPENROUTESERVICE_BASE_URL=https://api.openrouteservice.org
# Render (réseau privé) : défini automatiquement par le Blueprint, ne pas mettre en local.
# OPENROUTESERVICE_HOSTPORT=
# Clé API (obligatoire sur l’API publique). Optionnel si ORS self-hosted sans auth.
OPENROUTESERVICE_API_KEY=
# Forcer la présence d’une clé même en self-hosted : OPENROUTESERVICE_REQUIRE_API_KEY=true
# Tests locaux sans clé sur l’API publique (déconseillé) : OPENROUTESERVICE_SKIP_API_KEY=true
# Profil : foot-walking | foot-hiking | cycling-regular | cycling-road | cycling-electric | driving-car
OPENROUTESERVICE_PROFILE=foot-walking

# Google Places — optional suggestions near a point on the trip builder (Nearby Search API key)
GOOGLE_PLACES_API_KEY=

# Email (optional — magic link)
RESEND_API_KEY=
EMAIL_FROM="TripHive <onboarding@resend.dev>"

# Realtime (optional — Railway)
REALTIME_INTERNAL_URL=http://localhost:4001
REALTIME_SECRET=change-me
NEXT_PUBLIC_REALTIME_URL=http://localhost:4001

# Uploadthing / R2 (optional)
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=
